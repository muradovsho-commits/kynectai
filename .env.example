# Convex (required for auth, dashboard, contact finder)
# Get this URL by running: npx convex dev
# Then create a Convex project or link an existing one — the URL will be printed in the terminal.
NEXT_PUBLIC_CONVEX_URL=

# Apollo API (optional — used for contact search in Contact Finder)
# Get a key at https://app.apollo.io
APOLLO_API_KEY=
